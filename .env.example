# Public Key do Mercado Pago (não é segredo — é usada no navegador para
# inicializar o SDK de pagamento). Pegue em:
# https://www.mercadopago.com.br/developers/panel > Suas integrações > [app] > Credenciais
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=

# As variáveis abaixo são SECRETAS e usadas pelas Cloudflare Pages Functions
# (pasta /functions), nunca pelo código do navegador. Configure-as no painel
# do Cloudflare Pages em Settings > Environment variables — não em arquivo
# .env, que não é lido pelas Functions em produção.
#
# MERCADOPAGO_ACCESS_TOKEN=
# MERCADOPAGO_WEBHOOK_SECRET=
# FIREBASE_PROJECT_ID=
# FIREBASE_SERVICE_ACCOUNT=   (conteúdo JSON da service account, em uma linha)
