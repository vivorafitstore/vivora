rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function ehAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    match /produtos/{id} {
      allow read: if true;
      allow write: if ehAdmin();
    }

    match /categorias/{id} {
      allow read: if true;
      allow write: if ehAdmin();
    }

    match /pedidos/{id} {
      // Admin tem acesso total. Cliente logado lê o próprio pedido.
      // Leitura pública (sem login) é permitida SOMENTE quando o pedido já
      // tem um código de rastreio cadastrado — é o que a página pública
      // /rastreio/[codigo] usa, e só quem tem o link/código em mãos
      // consegue de fato chegar a esse pedido (não é uma listagem aberta).
      allow read: if ehAdmin() ||
        (request.auth != null && resource.data.clienteId == request.auth.uid) ||
        (resource.data.codigoRastreio is string && resource.data.codigoRastreio.size() > 0);
      allow create: if ehAdmin() ||
        (request.auth != null && request.resource.data.clienteId == request.auth.uid);
      allow update, delete: if ehAdmin();
    }

    match /usuarios/{uid} {
      // Cada cliente só lê/escreve o próprio documento. Admin também
      // pode ler (útil para o painel mostrar dados do cliente futuramente).
      allow read: if ehAdmin() || (request.auth != null && request.auth.uid == uid);
      allow write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
